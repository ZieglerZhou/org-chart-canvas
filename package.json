{
  "name": "org-chart-canvas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode development & electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.orgchart.canvas",
    "productName": "组织架构画布",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "组织架构画布"
    },
    "portable": {
      "artifactName": "组织架构画布-${version}.exe"
    }
  },
  "devDependencies": {
    "@electron/packager": "^20.0.4",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.11.2",
    "html-to-image": "^1.11.13",
    "pinyin-pro": "^3.28.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "xlsx": "^0.18.5"
  }
}
